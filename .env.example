# Database
MONGODB_URI=mongodb://localhost:27017/grc-services

# JWT Configuration
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_DOMAIN=localhost

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Application Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
APP_NAME=GRC Services
APP_VERSION=1.0.0

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@grcservices.com

# DigitalOcean Spaces (S3-compatible)
SPACES_REGION=blr1
SPACES_ENDPOINT=https://blr1.digitaloceanspaces.com
SPACES_BUCKET=your-space-name
SPACES_ACCESS_KEY_ID=your-access-key
SPACES_SECRET_ACCESS_KEY=your-secret-key
SPACES_CDN_BASE_URL=https://your-space-name.blr1.cdn.digitaloceanspaces.com
SPACES_SIGNED_URL_TTL_SECONDS=900

# Razorpay
RAJORPAY_KEY_ID=
RAJORPAY_KEY_SECRET=
RAJORPAY_WEBHOOK_SECRET=
